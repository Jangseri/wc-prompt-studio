# wc-prompt-studio production environment template.
# Copy to `.env` on the deploy server and fill in real values.
# Do NOT commit the populated .env file (gitignored).

# ── LLM ────────────────────────────────────────────────────────────────
# OpenAI: text generation (gpt-4o) + vision fallback (gpt-5).
OPENAI_API_KEY=sk-...

# Gemini: vision 1st choice (gemini-2.5-flash). On failure (429/404/etc)
# the app falls back to OpenAI automatically — Gemini is therefore
# optional, but recommended for cost.
GEMINI_API_KEY=AIza...

# ── Database (사내 MySQL) ──────────────────────────────────────────────
DB_HOST=192.168.220.222
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=orchestrator

# ── Internal services (사내 Orchestrator + CompanyInfo) ────────────────
ORCHESTRATOR_URL=http://192.168.220.222:9002
COMPANY_INFO_URL=http://192.168.220.222:3030
